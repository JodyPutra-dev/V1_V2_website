{
  "name": "urine-disease-detection-v2-nginx-pm2",
  "version": "2.0.0-v2-optimized",
  "description": "Version 2 (NGINX+PM2 Optimized) - Production-ready Node.js deployment with NGINX reverse proxy and PM2 clustering",
  "main": "microservices/gateway/gateway.js",
  "_comment_optimization": "VERSION 2 OPTIMIZATION: express-rate-limit and compression packages are EXCLUDED from Version 2 because NGINX handles these responsibilities more efficiently: Rate limiting via NGINX limit_req_zone (kernel-level) vs express-rate-limit (application-level). Compression via NGINX gzip (native C) vs compression middleware (JavaScript). This demonstrates NGINX offloading strategy: HTTP-level operations handled by NGINX, business logic handled by Node.js. See VERSION_2_OPTIMIZATIONS.md for details.",
  "scripts": {
    "start": "./start.sh",
    "stop": "./stop.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "build:frontend": "cd frontend && REACT_APP_USE_NGINX=true npm run build",
    "test:load": "k6 run -e MODE=nginx-pm2 -e VUS=100 -e BASE_URL=https://localhost:7763 ../../K6/k6-prediction-focused-test.js",
    "test:load:10": "k6 run -e MODE=nginx-pm2 -e VUS=10 ../../K6/k6-prediction-focused-test.js",
    "test:load:25": "k6 run -e MODE=nginx-pm2 -e VUS=25 ../../K6/k6-prediction-focused-test.js",
    "test:load:50": "k6 run -e MODE=nginx-pm2 -e VUS=50 ../../K6/k6-prediction-focused-test.js",
    "test:load:100": "k6 run -e MODE=nginx-pm2 -e VUS=100 ../../K6/k6-prediction-focused-test.js",
    "test:hydration": "bash test-hydration-analysis.sh",
    "nginx:test": "sudo nginx -t",
    "nginx:reload": "sudo systemctl reload nginx",
    "nginx:start": "sudo systemctl start nginx",
    "nginx:stop": "sudo systemctl stop nginx"
  },
  "dependencies": {
    "abort-controller": "^3.0.0",
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "form-data": "^4.0.0",
    "helmet": "^6.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^6.13.8",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.3",
    "pm2": "^5.4.3",
    "sharp": "^0.34.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "license": "MIT",
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "ml",
    "urine-detection",
    "thesis",
    "performance",
    "nginx",
    "pm2",
    "optimized",
    "production"
  ],
  "author": "Thesis Research - Version 2 Optimized"
}
