                  "    ).to.exist;\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "const instanceId = json.instanceId || json.instance || \"unknown\";\r",
                  "const pid = json.pid || \"unknown\";\r",
                  "const port = json.server?.port || json.port || \"unknown\";\r",
                  "\r",
                  "let calls = pm.environment.get(\"it07_worker_calls\");\r",
                  "\r",
                  "if (!calls) {\r",
                  "    calls = [];\r",
                  "} else {\r",
                  "    calls = JSON.parse(calls);\r",
                  "}\r",
                  "\r",
                  "calls.push({\r",
                  "    instanceId,\r",
                  "    pid,\r",
                  "    port\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"it07_worker_calls\", JSON.stringify(calls));\r",
                  "\r",
                  "console.log(\"IT-07 Worker Call:\", {\r",
                  "    call: calls.length,\r",
                  "    instanceId,\r",
                  "    pid,\r",
                  "    port\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Worker call tercatat\", () => {\r",
                  "    pm.expect(calls.length).to.be.greaterThan(0);\r",
                  "});"
